# Python
__pycache__/
*.py[cod]
.venv/
venv/

# runtime output (generated by the emulator)
/thumbnails/
# covers the user chose: DATA, not output -- the app only ever reads this folder
/covers/
/savestates/
/watches/
/screenshots/
/crashes/
/saves/
system_ram.bin
*.state
# play history (per-user: play counts, playtime, favourites)
/library.json

# user content (never distribute ROMs/BIOS)
/roms/*.ngc
/roms/*.ngp
/bios.bin

# standalone-exe build (PyInstaller): keep build_exe.bat, ignore everything it generates
/build/
/release/
/dist/
# Ignore auto-generated specs, but TRACK the maintained one -- CI builds from it,
# so it must be in the repo (a fresh checkout has no other copy).
*.spec
!NgpCraftEmulator.spec

# dev-internal docs (kept in the repo for convenience, never distributed)
/DEVLOG.md

# native build artifacts (keep the prebuilt cpp/build/ngpc_core.dll)
/cpp/build/CMakeFiles/
/cpp/build/*.cmake
/cpp/build/CMakeCache.txt
/cpp/build/Makefile
*.o
*.obj
*.ilk
*.pdb
*.exp
*.lib
